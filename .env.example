# CR Management System
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CLIENT_ORIGIN=http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=postgresql://sap_cr_app:password@localhost:5432/sap_cr_management
PGHOST=localhost
PGPORT=5432
PGDATABASE=sap_cr_management
PGUSER=sap_cr_app
PGPASSWORD=change-me
PGSCHEMA=cr_management

# Optional GLPI MariaDB read-only source for realtime GLPI value help.
GLPI_DB_ENABLED=false
GLPI_DB_HOST=
GLPI_DB_PORT=3306
GLPI_DB_NAME=
GLPI_DB_USER=
GLPI_DB_PASSWORD=
GLPI_DB_CONNECTION_LIMIT=5
GLPI_DB_TABLE=glpi_tickets
GLPI_DB_ID_COLUMN=id
GLPI_DB_TITLE_COLUMN=name
GLPI_DB_OPENED_AT_COLUMN=date
GLPI_DB_STATUS_COLUMN=status

# SAP connector
# internal = use bundled connector in this web project.
# external = use SAP_AGENT_PLATFORM_DIR as legacy fallback.
# disabled = keep web/API running from database only; Sync CR will be unavailable.
SAP_CONNECTOR_MODE=internal
SAP_DISCOVERY_SCRIPT=scripts/sap-discovery.mjs
SAP_AGENT_PLATFORM_DIR=

# SAP CR landscape
SAP_CR_SYSTEMS=DEV,QA,PRD
SAP_CR_DEFAULT_SYSTEM=DEV

# DEV is the initial ABAP source server focus.
SAP_CR_DEV_SERVER=SAP_DEV_AIX
SAP_CR_DEV_OWNER=TRSTDEV
SAP_CR_DEV_DAYS=30
SAP_CR_DEV_ENABLED=true

# Future placeholders. Fill these after QA/PRD RFC destinations are available in SAP Agent platform.
SAP_CR_QA_SERVER=SAP_QA
SAP_CR_QA_OWNER=TRSTDEV
SAP_CR_QA_DAYS=30
SAP_CR_QA_ENABLED=true

SAP_CR_PRD_SERVER=SAP_PRD
SAP_CR_PRD_OWNER=TRSTDEV
SAP_CR_PRD_DAYS=30
SAP_CR_PRD_ENABLED=true

# Optional automatic incremental sync. It polls SAP only when cached data is stale.
SAP_CR_AUTO_SYNC_ENABLED=true
SAP_CR_AUTO_SYNC_SYSTEMS=DEV,QA,PRD
SAP_CR_AUTO_SYNC_INTERVAL_MINUTES=240
SAP_CR_AUTO_SYNC_LOOKBACK_DAYS=3
SAP_CR_AUTO_SYNC_ROW_COUNT=5000
SAP_CR_AUTO_SYNC_STALE_HOURS=24

# Recover old transports found in QA/PRD import logs when their DEV parent CR is not cached yet.
SAP_CR_ORPHAN_RECOVERY_ENABLED=true
SAP_CR_ORPHAN_RECOVERY_MAX_PER_SYNC=200
